{
  "manifest_version": 3,
  "name": "Runestone Web Clipper",
  "version": "1.0",
  "description": "Clip web pages to your Runestone knowledge graph.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
