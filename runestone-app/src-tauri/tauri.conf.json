{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Runestone",
  "version": "0.1.0",
  "identifier": "com.runestone.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Runestone",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug",
      "minSdkVersion": 26
    },
    "iOS": {
      "minimumSystemVersion": "15.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["runestone"]
      }
    }
  }
}
